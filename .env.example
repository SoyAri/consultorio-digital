# Configuración del Servidor
PORT=3000
NODE_ENV=development

# Configuración de Base de Datos
# Reemplaza los valores con tu configuración local o de producción en el archivo .env real. ¡Nunca subas el archivo .env!
DB_HOST=localhost
DB_PORT=5432
DB_USER=usuario_bd
DB_PASSWORD=contraseña_segura
DB_NAME=consultorio_digital

# Seguridad y Autenticación
# IMPORTANTE: Para generar una clave secreta fuerte, puedes usar en tu terminal:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=tu_secreto_super_seguro_aqui
JWT_EXPIRES_IN=1d

# Otros servicios o integraciones
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# STRIPE_API_KEY=
